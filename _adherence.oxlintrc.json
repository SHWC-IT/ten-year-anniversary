{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/patterns/**",
              "giving.js",
              "home.js",
              "image-slot.js",
              "shwc.js",
              "store.js",
              "ui_kits/anniversary-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cinzel|Italiana|Cormorant Garamond|Great Vibes|Pinyon Script|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Cinzel, Italiana, Cormorant Garamond, Great Vibes, Pinyon Script, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|muted)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'outline' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|wide|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, wide, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|align|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, align, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<Eyebrow> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<FieldOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='FramedPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|align|glow|style|key|ref|className|style|children)$/]",
        "message": "<FramedPanel> doesn't accept that prop. Declared props: children, align, glow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FramedPanel'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<FramedPanel> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|image|href|cta|external|onBuy|style|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, price, image, href, cta, external, onBuy, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:dow|day|month|title|description|venue|venueHref|time|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ScheduleRow> doesn't accept that prop. Declared props: dow, day, month, title, description, venue, venueHref, time, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|script|align|as|style|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: children, script, align, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionTitle> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3)$/]",
        "message": "<SectionTitle> as must be one of 'h1' | 'h2' | 'h3'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
